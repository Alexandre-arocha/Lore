# Atlas API — variáveis de ambiente
# Copie para api/.env e ajuste conforme necessário.

# Porta HTTP da API
PORT=8080

# Ambiente: development | production
APP_ENV=development

# String de conexão do PostgreSQL.
# Dev (docker compose): postgres://atlas:atlas@localhost:5432/atlas?sslmode=disable
# Prod (Neon/Supabase): use a connection string fornecida pelo provedor.
DATABASE_URL=postgres://atlas:atlas@localhost:5432/atlas?sslmode=disable

# Token exigido nos endpoints /api/admin/* (header X-Admin-Token).
# Em produção, use uma string longa e aleatória.
ADMIN_TOKEN=change-me

# Token do GitHub para a ingestão (eleva o rate limit da API do GitHub).
# Opcional, mas recomendado. Sem ele a ingestão usa o limite anônimo.
GITHUB_TOKEN=
